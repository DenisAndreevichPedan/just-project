{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
      "typecheck": {},
      "build": {
        "dependsOn": ["^build"],
        "outputs": [".next/**", "dist/**"]
      },
      "dev": {
        "persistent": true,
        "cache": false
      },
      "test": {
        "dependsOn": ["^test"],
        "outputs": []
      },
      "lint": {}
    }
  }